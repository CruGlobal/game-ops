<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Leaderboard - Game Ops</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;500;600;700;800&family=Roboto+Mono:wght@400;500&display=swap">
    <link rel="stylesheet" href="/modern-design-system.css">
    <link rel="stylesheet" href="/styles.css">
    <link rel="stylesheet" href="/leaderboard.css">
    <link rel="stylesheet" href="/animations.css">
    <!-- Ops Terminal theme — loaded last to override -->
    <link rel="stylesheet" href="/game-ops-theme.css">
</head>
<body>
<a href="#main-content" class="skip-link">Skip to main content</a>
<div class="container">
    <div class="header-section">
        <h1>🏆 Leaderboard</h1>
        <div class="hamburger-menu">
            <button class="hamburger-button" aria-label="Toggle navigation menu" aria-expanded="false">&#9776;</button>
            <%- include('partials/nav') %>
        </div>
    </div>

    <!-- Arcade contribution-graph header (self-hosted Canvas; real activity) -->
    <section class="arcade-header" aria-label="Arcade contribution animation">
        <div id="arcade-graph" class="arcade-graph" role="img" aria-label="Arcade contribution animation"></div>
        <div class="arcade-controls">
            <span class="arcade-score" id="arcade-score" aria-live="polite"></span>
            <button type="button" class="arcade-play" id="arcade-play" aria-pressed="false">▶ Play</button>
            <label for="arcade-select">🕹️</label>
            <select id="arcade-select" aria-label="Choose which arcade game to play"></select>
        </div>
    </section>

    <!-- Search and Filter Bar -->
    <div class="controls-section" role="search" aria-label="Leaderboard controls">
        <div class="search-bar">
            <input
                type="text"
                id="search-input"
                placeholder="🔍 Search contributors..."
                aria-label="Search contributors by username"
            />
        </div>
        <div class="filter-dropdown">
            <label for="sort-select">View:</label>
            <select id="sort-select" aria-label="Choose leaderboard ranking">
                <option value="totalPoints" selected>Top Points</option>
                <option value="prCount">Top Contributors</option>
                <option value="reviewCount">Top Reviewers</option>
                <option value="currentStreak">Top Streaks</option>
                <option value="longestStreak">Longest Streak</option>
            </select>
        </div>
        <!-- DevOps Filter Toggle (only visible to DevOps members) -->
        <div id="devops-filter-container" style="display: <%= user && user.isDevOps ? 'flex' : 'none' %>;" class="devops-filter-toggle">
            <label for="show-devops-toggle">
                <input type="checkbox" id="show-devops-toggle" checked />
                Show DevOps Members
            </label>
        </div>
    </div>

    <!-- Winners Banner (shown for 7 days after quarter ends) -->
    <div id="winners-banner" class="winners-banner" style="display: none;">
        <button class="winners-banner-dismiss" aria-label="Dismiss winners banner">&times;</button>
        <div class="winners-banner-content" id="winners-banner-content"></div>
    </div>

    <!-- Tabs -->
    <div class="tabs" role="tablist" aria-label="Leaderboard categories">
        <button class="tab-button active" data-tab="all-time" role="tab" aria-selected="true" aria-controls="all-time" id="tab-all-time">🌟 All-Time</button>
        <button class="tab-button" data-tab="quarterly" role="tab" aria-selected="false" aria-controls="quarterly" id="tab-quarterly">📅 This Quarter</button>
        <button class="tab-button" data-tab="hall-of-fame" role="tab" aria-selected="false" aria-controls="hall-of-fame" id="tab-hall-of-fame">🏆 Hall of Fame</button>
    </div>

    <!-- All-Time Leaderboard Tab -->
    <main id="main-content">
        <div class="tab-content active" id="all-time" role="tabpanel" aria-labelledby="tab-all-time">
            <div class="quarter-info" id="all-time-info">
                <p class="quarter-description">All-time top contributors based on total points earned</p>
            </div>
            <table class="leaderboard-table" id="all-time-table">
                <thead>
                    <tr>
                        <th class="rank-col" scope="col">Rank</th>
                        <th class="dev-col" scope="col">Developer</th>
                        <th class="num-col" data-sortkey="prCount" scope="col">PRs</th>
                        <th class="num-col" data-sortkey="reviewCount" scope="col">Reviews</th>
                        <th class="num-col" data-sortkey="allTimePoints" scope="col">Points</th>
                        <th class="num-col" data-sortkey="currentStreak" scope="col">Streak</th>
                    </tr>
                </thead>
                <tbody class="leaderboard-grid" id="all-time-grid" aria-live="polite" aria-atomic="false"></tbody>
            </table>
        </div>

        <!-- Quarterly Leaderboard Tab -->
        <div class="tab-content" id="quarterly" role="tabpanel" aria-labelledby="tab-quarterly" hidden>
            <div class="quarter-info" id="quarterly-info">
                <h3 id="current-quarter-title">Loading...</h3>
                <p id="current-quarter-dates" class="quarter-description">Loading quarter information...</p>
            </div>
            <table class="leaderboard-table" id="quarterly-table">
                <thead>
                    <tr>
                        <th class="rank-col" scope="col">Rank</th>
                        <th class="dev-col" scope="col">Developer</th>
                        <th class="num-col" scope="col">PRs</th>
                        <th class="num-col" scope="col">Reviews</th>
                        <th class="num-col" scope="col">Points</th>
                        <th class="num-col" scope="col">Streak</th>
                    </tr>
                </thead>
                <tbody class="leaderboard-grid" id="quarterly-grid" aria-live="polite" aria-atomic="false"></tbody>
            </table>
        </div>

        <!-- Hall of Fame Tab -->
        <div class="tab-content" id="hall-of-fame" role="tabpanel" aria-labelledby="tab-hall-of-fame" hidden>
            <div class="quarter-info">
                <p class="quarter-description">Past quarterly champions and top performers</p>
            </div>
            <div class="hall-of-fame-container" id="hall-of-fame-container" aria-live="polite" aria-atomic="false"></div>
        </div>

    </main>
</div>

<!-- Socket.IO Client Library -->
<script src="/socket.io/socket.io.js"></script>
<!-- Custom Scripts -->
<script src="/notification-settings.js"></script>
<script src="/confetti.js"></script>
<script nonce="<%= nonce %>" src="/socket-client.js"></script>
<script nonce="<%= nonce %>" src="/leaderboard-client.js"></script>
<script nonce="<%= nonce %>" src="/theme-toggle.js"></script>
<script src="/init.js"></script>
<!-- Self-hosted arcade header (Canvas; no external deps) -->
<script src="/arcade.js"></script>
</body>
</html>
